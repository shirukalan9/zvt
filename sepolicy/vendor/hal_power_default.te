# Allow libperfmgr to access Transsion DT2W Nodes
allow hal_power_default proc_gesture_function:dir r_file_perms;
allow hal_power_default proc_gesture_function:file rw_file_perms;

# Allow libperfmgr to control cgroups
allow hal_power_default cgroup:file rw_file_perms;

# Allow libperfmgr to write GPU nodes
allow hal_power_default sysfs_gpu:dir r_dir_perms;
allow hal_power_default sysfs_gpu:file rw_file_perms;
allow hal_power_default sysfs_gpu:dir search;

# Allow libperfmgr to control cpu frequencies
allow hal_power_default sysfs_devices_system_cpu:file rw_file_perms;
allow hal_power_default proc_cpufreq:dir search;
allow hal_power_default proc_cpufreq:file rw_file_perms;

# Allow libperfmgr to control GPU boost
allow hal_power_default sysfs_ged:dir r_dir_perms;
allow hal_power_default sysfs_ged:file rw_file_perms;

# Allow libperfmgr to control mtk-dvfsrc-devfreq
allow hal_power_default sysfs_dvfsrc_devfreq:dir r_dir_perms;
allow hal_power_default sysfs_dvfsrc_devfreq:file rw_file_perms;

# Allow libperfmgr to control task turbo
r_dir_file(hal_power_default, sysfs_task_turbo)
allow hal_power_default sysfs_task_turbo:file w_file_perms;

# Allow libperfmgr to access Touch Panel Nodes
allow hal_power_default proc_game_state:dir { ioctl read getattr lock open watch watch_reads search };
allow hal_power_default proc_game_state:file { ioctl read write getattr lock append map open watch watch_reads };
allow hal_power_default proc_game_state:lnk_file { ioctl read write getattr lock append map open watch watch_reads };

# Allow libperfmgr to control CciFreq
allow hal_power_default sysfs_cm_mgr:dir r_dir_perms;
allow hal_power_default sysfs_cm_mgr:file rw_file_perms;

dontaudit hal_power_default self:capability dac_override;

set_prop(hal_power_default, vendor_power_prop)
